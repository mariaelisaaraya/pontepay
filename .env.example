# ── Privy (auth + embedded wallets) ──────────────────────────────────────────
# Get your App ID at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# ── Stellar / Soroban ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# P2P escrow contract deployed on Soroban testnet
NEXT_PUBLIC_P2P_CONTRACT_ID=CCCIAD3CI5I6MRQ6TDGKN7G3EMIH5OZS2EVAVJXO2U4NASPQL7Z7VS5R

# Reflector SEP-40 fiat exchange-rate oracle (testnet)
NEXT_PUBLIC_REFLECTOR_FIAT_ORACLE_ID=CCSSOHTBL3LEWUCBBEB5NJFC2OKFRC74OWEIJIZLRJBGAAU4VMU5NV4W

# ── Platform wallet ───────────────────────────────────────────────────────────
# Public address shown to users for dispute resolution / platform fees
NEXT_PUBLIC_PLATFORM_ADDRESS=
# Secret key used server-side to sign platform operations (never expose client-side)
PLATFORM_SECRET=

# ── Faucet ────────────────────────────────────────────────────────────────────
# Sends 5 USDC to new users on first login
FAUCET_SECRET_KEY=

# ── Trustless Work (escrow API) ───────────────────────────────────────────────
# Get your API key at https://dashboard.trustlesswork.com
TRUSTLESS_WORK_API_KEY=
TRUSTLESS_WORK_BASE_URL=https://api.trustlesswork.com

# ── SEP-24 Anchor (fiat on/off-ramp) ─────────────────────────────────────────
# Domain of the SEP-24 anchor used for ARS deposits/withdrawals
NEXT_PUBLIC_SEP24_ANCHOR_DOMAIN=

# ── DeFindex (yield vaults) ───────────────────────────────────────────────────
# Get your API key at https://api.defindex.io/register
DEFINDEX_API_KEY=

# ── Privy server-side (profile sync via custom metadata) ─────────────────────
# Dashboard → your app → Settings → API keys → App secret
PRIVY_APP_SECRET=

# ── Marketplace demo orders ───────────────────────────────────────────────────
# Demo orders are mixed into the order book by default so the flow is testable.
# Set to "false" to show only real on-chain orders.
NEXT_PUBLIC_DEMO_ORDERS=
# Vault DeFindex cuyo asset es el USDC de Circle (mismo que usa la app)
DEFINDEX_VAULT_ADDRESS=
